# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Google Cloud (Vertex AI)
GOOGLE_CLOUD_PROJECT=your_gcloud_project_id
VERTEX_AI_LOCATION=us-east5

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Gmail (notifications — use an App Password, not your regular password)
# Enable at: myaccount.google.com/apppasswords  (requires 2FA to be on)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Ticketmaster (developer.ticketmaster.com — free account, for local event discovery)
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# Amadeus (developers.amadeus.com — free account, for flight deal search)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Agent scheduling (how often the opportunity + travel agents run)
AGENT_RUN_INTERVAL_DAYS=2

# Google Application Default Credentials (for Vertex AI / Claude)
# Point this to the same service account JSON used for Firebase
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
