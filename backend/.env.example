# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Gmail — use an App Password (not your regular password)
# Enable at: myaccount.google.com/apppasswords  (requires 2-Step Verification)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# SQLite database path (relative to backend/)
DB_PATH=./family_calendar.db

# Anthropic — optional; add to enable AI activity suggestions
# Get your key at: console.anthropic.com
# ANTHROPIC_API_KEY=

# Google OAuth — optional; add to enable Google Sign-In and Calendar sync
# console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=postmessage
