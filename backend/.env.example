# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Calendar API and create an OAuth 2.0 Web Client ID.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=postmessage

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Gmail — use an App Password (not your regular password)
# Enable at: myaccount.google.com/apppasswords  (requires 2-Step Verification)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# SQLite database path (relative to backend/)
DB_PATH=./family_calendar.db
